<Window x:Class="ScreenshotScraper.App.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ScreenshotScraper"
        Height="760"
        Width="1200"
        MinHeight="600"
        MinWidth="960">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button Content="Capture"
                    Width="120"
                    Margin="0,0,12,0"
                    Padding="12,6"
                    Click="CaptureButton_Click" />
            <Button Content="Generate XML"
                    Width="120"
                    Padding="12,6"
                    Click="BuildXmlButton_Click" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="Preview">
                <Grid>
                    <Border BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            Background="#FAFAFA"
                            Padding="8">
                        <Grid>
                            <Image Source="{Binding PreviewImage}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                            <TextBlock Text="{Binding PreviewStatus}"
                                       Foreground="Gray"
                                       FontStyle="Italic"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="24" />
                        </Grid>
                    </Border>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Capture Metadata">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,0,0,8"
                               Text="{Binding StatusMessage}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBox Text="{Binding CaptureMetadata, Mode=OneWay}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             FontFamily="Consolas" />
                </DockPanel>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="4" Header="Extracted Fields">
            <DataGrid ItemsSource="{Binding ExtractedFields}"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Raw Text" Binding="{Binding RawText}" Width="2*" />
                    <DataGridTextColumn Header="Parsed Value" Binding="{Binding ParsedValue}" Width="2*" />
                    <DataGridCheckBoxColumn Header="Valid" Binding="{Binding IsValid}" Width="Auto" />
                    <DataGridTextColumn Header="Error" Binding="{Binding Error}" Width="2*" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Row="6" Header="XML / Status">
            <TextBox Text="{Binding XmlContent, Mode=OneWay}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="Wrap"
                     FontFamily="Consolas" />
        </GroupBox>
    </Grid>
</Window>
