<Window x:Class="ScreenshotScraper.App.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ScreenshotScraper"
        Height="900"
        Width="1320"
        MinHeight="700"
        MinWidth="1080">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button Content="Capture"
                    Width="120"
                    Margin="0,0,12,0"
                    Padding="12,6"
                    Click="CaptureButton_Click" />
            <Button Content="Upload Screenshot"
                    Width="160"
                    Margin="0,0,12,0"
                    Padding="12,6"
                    Click="UploadScreenshotButton_Click" />
            <Button Content="Generate XML"
                    Width="120"
                    Padding="12,6"
                    Click="BuildXmlButton_Click" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="Preview">
                <Grid>
                    <Border BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            Background="#FAFAFA"
                            Padding="8">
                        <Grid>
                            <Image Source="{Binding PreviewImage}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                            <TextBlock Text="{Binding PreviewStatus}"
                                       Foreground="Gray"
                                       FontStyle="Italic"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="24" />
                        </Grid>
                    </Border>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Capture Metadata">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,0,0,8"
                               Text="{Binding StatusMessage}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBox Text="{Binding CaptureMetadata, Mode=OneWay}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             FontFamily="Consolas" />
                </DockPanel>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="4" Header="Extracted Fields">
            <DataGrid ItemsSource="{Binding ExtractedFields}"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Raw Text" Binding="{Binding RawText}" Width="2*" />
                    <DataGridTextColumn Header="Parsed Value" Binding="{Binding ParsedValue}" Width="2*" />
                    <DataGridCheckBoxColumn Header="Valid" Binding="{Binding IsValid}" Width="Auto" />
                    <DataGridTextColumn Header="Confidence" Binding="{Binding Confidence, StringFormat={}{0:P0}}" Width="Auto" />
                    <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="2*" />
                    <DataGridTextColumn Header="Error" Binding="{Binding Error}" Width="2*" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Row="6" Header="XML / Seat ROI Debug">
            <TabControl>
                <TabItem Header="XML / Status">
                    <TextBox Text="{Binding XmlContent, Mode=OneWay}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             FontFamily="Consolas" />
                </TabItem>
                <TabItem Header="Seat ROI Debug">
                    <DockPanel Margin="8">
                        <TextBox DockPanel.Dock="Top"
                                 Margin="0,0,0,8"
                                 Text="{Binding SeatRoiStatus, Mode=OneWay}"
                                 FontFamily="Consolas"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="80" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding SeatRoiDebugItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#D0D0D0" BorderThickness="1" Padding="6" Margin="4">
                                            <StackPanel>
                                                <TextBlock Text="{Binding OccupancyLabel}" FontWeight="Bold" Margin="0,0,0,4" />
                                                <Image Source="{Binding FullRoiImage}" Height="90" Stretch="Uniform" Margin="0,0,0,4" />
                                                <WrapPanel>
                                                    <StackPanel Margin="0,0,6,0">
                                                        <TextBlock Text="Name ROI" FontSize="11" />
                                                        <Image Source="{Binding NameRoiImage}" Height="42" Width="110" Stretch="Uniform" />
                                                        <TextBlock Text="{Binding NameBounds}" FontSize="10" TextWrapping="Wrap" Width="110" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,6,0">
                                                        <TextBlock Text="Stack ROI" FontSize="11" />
                                                        <Image Source="{Binding StackRoiImage}" Height="42" Width="110" Stretch="Uniform" />
                                                        <TextBlock Text="{Binding StackBounds}" FontSize="10" TextWrapping="Wrap" Width="110" />
                                                    </StackPanel>
                                                    <StackPanel>
                                                        <TextBlock Text="Bet ROI" FontSize="11" />
                                                        <Image Source="{Binding BetRoiImage}" Height="42" Width="110" Stretch="Uniform" />
                                                        <TextBlock Text="{Binding BetBounds}" FontSize="10" TextWrapping="Wrap" Width="110" />
                                                    </StackPanel>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </TabItem>
            </TabControl>
        </GroupBox>
    </Grid>
</Window>
