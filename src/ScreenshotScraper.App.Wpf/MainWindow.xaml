<Window x:Class="ScreenshotScraper.App.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ScreenshotScraper"
        Height="900"
        Width="1320"
        MinHeight="700"
        MinWidth="1080">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button Content="Capture"
                    Width="120"
                    Margin="0,0,12,0"
                    Padding="12,6"
                    Click="CaptureButton_Click" />
            <Button Content="Upload Screenshot"
                    Width="160"
                    Margin="0,0,12,0"
                    Padding="12,6"
                    Click="UploadScreenshotButton_Click" />
            <Button Content="Generate XML"
                    Width="120"
                    Padding="12,6"
                    Click="BuildXmlButton_Click" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="Preview">
                <Grid>
                    <Border BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            Background="#FAFAFA"
                            Padding="8">
                        <Grid>
                            <Image Source="{Binding PreviewImage}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                            <TextBlock Text="{Binding PreviewStatus}"
                                       Foreground="Gray"
                                       FontStyle="Italic"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="24" />
                        </Grid>
                    </Border>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Capture Metadata">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,0,0,8"
                               Text="{Binding StatusMessage}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBox Text="{Binding CaptureMetadata, Mode=OneWay}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             FontFamily="Consolas" />
                </DockPanel>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="4" Header="Extracted Fields">
            <DataGrid ItemsSource="{Binding ExtractedFields}"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Raw Text" Binding="{Binding RawText}" Width="2*" />
                    <DataGridTextColumn Header="Parsed Value" Binding="{Binding ParsedValue}" Width="2*" />
                    <DataGridCheckBoxColumn Header="Valid" Binding="{Binding IsValid}" Width="Auto" />
                    <DataGridTextColumn Header="Confidence" Binding="{Binding Confidence, StringFormat={}{0:P0}}" Width="Auto" />
                    <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="2*" />
                    <DataGridTextColumn Header="Error" Binding="{Binding Error}" Width="2*" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Row="6" Header="XML / Seat ROI Debug">
            <TabControl>
                <TabItem Header="XML / Status">
                    <TextBox Text="{Binding XmlContent, Mode=OneWay}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             FontFamily="Consolas" />
                </TabItem>
                <TabItem Header="Seat ROI Debug">
                    <DockPanel Margin="8">
                        <TextBox DockPanel.Dock="Top"
                                 Margin="0,0,0,8"
                                 Text="{Binding SeatRoiStatus, Mode=OneWay}"
                                 FontFamily="Consolas"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="80" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding SeatRoiDebugItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#D0D0D0" BorderThickness="1" Padding="6" Margin="4">
                                            <StackPanel>
                                                <TextBlock Text="{Binding OccupancyLabel}" FontWeight="Bold" Margin="0,0,0,4" />
                                                <Image Source="{Binding FullRoiImage}" Height="90" Stretch="Uniform" Margin="0,0,0,4" />
                                                <ItemsControl ItemsSource="{Binding Fields}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="#E4E4E4" BorderThickness="1" Padding="4" Margin="0,2,0,2">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding FieldType, StringFormat={}{0} field}" FontWeight="SemiBold" FontSize="11" />
                                                                    <TextBlock Text="{Binding Bounds}" FontSize="10" Foreground="#666666" />
                                                                    <WrapPanel Margin="0,3,0,3">
                                                                        <StackPanel Margin="0,0,8,0">
                                                                            <TextBlock Text="Raw ROI" FontSize="10" />
                                                                            <Image Source="{Binding RawRoiImage}" Height="40" Width="110" Stretch="Uniform" />
                                                                        </StackPanel>
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding SelectedVariant, StringFormat=OCR input ({0})}" FontSize="10" />
                                                                            <Image Source="{Binding SelectedOcrInputImage}" Height="40" Width="110" Stretch="Uniform" />
                                                                        </StackPanel>
                                                                    </WrapPanel>
                                                                    <TextBlock Text="{Binding ParsedValue, StringFormat=Parsed: {0}}" FontSize="10" />
                                                                    <TextBlock Text="{Binding ParseRejectionReason, StringFormat=Reject: {0}}" FontSize="10" Foreground="#9A6B00" TextWrapping="Wrap" />
                                                                    <ItemsControl ItemsSource="{Binding Variants}" Margin="0,4,0,0">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <WrapPanel />
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Border Padding="3"
                                                                                        Margin="0,0,4,4"
                                                                                        BorderThickness="1"
                                                                                        BorderBrush="#CFCFCF">
                                                                                    <StackPanel Width="110">
                                                                                        <TextBlock Text="{Binding VariantName}" FontSize="10" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                                                        <TextBlock Text="{Binding Selected, StringFormat=Selected: {0}}" FontSize="9" />
                                                                                        <Image Source="{Binding Image}" Height="34" Stretch="Uniform" />
                                                                                        <TextBlock Text="{Binding Backend, StringFormat=Backend: {0}}" FontSize="9" />
                                                                                        <TextBlock Text="{Binding ConfidenceText, StringFormat=Conf: {0}}" FontSize="9" />
                                                                                        <TextBlock Text="{Binding OcrRawText, StringFormat=Raw: {0}}" FontSize="9" TextWrapping="Wrap" MaxHeight="30" />
                                                                                    </StackPanel>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Paddle OCR Input">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  Padding="8">
                        <ItemsControl ItemsSource="{Binding SeatOcrInputDebugItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#D0D0D0"
                                            BorderThickness="1"
                                            Padding="8"
                                            Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SeatLabel}"
                                                       FontWeight="Bold"
                                                       Margin="0,0,0,6" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Name" FontWeight="SemiBold" Margin="0,0,0,4" />
                                                    <Image Source="{Binding NameImage}" Height="52" Stretch="Uniform" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Stack" FontWeight="SemiBold" Margin="0,0,0,4" />
                                                    <Image Source="{Binding StackImage}" Height="52" Stretch="Uniform" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="Bet" FontWeight="SemiBold" Margin="0,0,0,4" />
                                                    <Image Source="{Binding BetImage}" Height="52" Stretch="Uniform" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </GroupBox>
    </Grid>
</Window>
